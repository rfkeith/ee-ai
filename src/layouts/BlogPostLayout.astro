---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  category: string;
  tags: string[];
  readingTime?: number;
  sources?: Array<{ book: string; author: string }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  category,
  tags,
  readingTime,
  sources = [],
} = Astro.props;

const categoryLabel = category
  .split('-')
  .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
  .join(' ');

const pubDateLong = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedLong = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} withSidebar={false}>
  <article class="max-w-[76rem] mx-auto px-8 grid grid-cols-1 lg:grid-cols-[1fr_16rem] gap-12 lg:gap-18 py-12 lg:pb-20">

    <div class="min-w-0">
      <header class="mb-10">
        <div class="flex items-center gap-2.5 font-mono text-[0.7rem] text-muted mb-5 flex-wrap">
          <a
            href={`/blog/category/${category}/`}
            class="font-sans font-medium tracking-[0.14em] uppercase text-[0.7rem] text-accent no-underline hover:text-accent-deep"
          >
            {categoryLabel}
          </a>
          <span class="text-rule">·</span>
          <time datetime={pubDate.toISOString()}>{pubDateLong}</time>
          {updatedLong && (
            <>
              <span class="text-rule">·</span>
              <span>Updated <time datetime={updatedDate!.toISOString()}>{updatedLong}</time></span>
            </>
          )}
          {readingTime && (
            <>
              <span class="text-rule">·</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </div>

        <h1 class="font-sans font-medium text-ink leading-[1.08] tracking-[-0.024em] m-0 mb-4 text-[clamp(2rem,3.6vw,3rem)] max-w-[24ch]">
          {title}
        </h1>

        <p class="font-sans font-normal text-[1.2rem] leading-snug text-muted m-0 mb-6 max-w-[58ch]">
          {description}
        </p>

        <div class="flex items-center gap-2.5 font-mono text-[0.72rem] text-muted">
          <span>By <span class="text-ink">{author}</span></span>
          <span class="text-rule">·</span>
          <span>Engineering Excellence</span>
        </div>

        {tags.length > 0 && (
          <div class="mt-4 flex gap-4 flex-wrap font-mono text-[0.72rem]">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}/`}
                class="text-accent-soft hover:text-accent no-underline before:content-['#'] before:opacity-50"
              >{tag}</a>
            ))}
          </div>
        )}
      </header>

      <div class="prose prose-lg max-w-[38rem]">
        <slot />
      </div>
    </div>

    <aside class="min-w-0">
      {sources.length > 0 && (
        <div class="lg:sticky lg:top-20">
          <h3 class="font-sans text-[0.8rem] font-medium text-ink m-0 mb-4 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-accent inline-block rounded-[1px]"></span>
            Sources
          </h3>
          <ul class="flex flex-col gap-4 list-none m-0 p-0">
            {sources.map((src) => (
              <li class="text-sm leading-snug">
                <span class="font-serif italic text-ink text-[0.96rem]">{src.book}</span>
                <span class="block font-sans text-[0.8rem] text-muted mt-0.5">{src.author}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </article>
</BaseLayout>

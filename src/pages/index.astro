---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingEntry from '../components/ReadingEntry.astro';
import Sidebar from '../components/Sidebar.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalCount = sorted.length;
const issueLabel = `Vol. I · No. ${String(totalCount).padStart(3, '0')}`;
const today = new Date().toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Home"
  dekStrong="For engineers who care about the craft."
  dek="Long-form essays on leadership, career, and what AI changes inside large engineering organizations — every claim grounded in a book you can check yourself."
  meta={`${issueLabel} · ${today}`}
>
  <section>
    <div class="flex justify-between items-baseline mb-5">
      <h1 class="font-sans font-medium text-[0.95rem] tracking-[-0.005em] text-ink m-0">The reading list</h1>
      <span class="font-mono text-[0.7rem] text-muted-soft">
        {totalCount} {totalCount === 1 ? 'essay' : 'essays'} · most recent first
      </span>
    </div>

    {sorted.length > 0 ? (
      <ol class="list-none m-0 p-0">
        {sorted.map((post, i) => (
          <ReadingEntry
            num={totalCount - i}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            url={`/blog/${post.id}/`}
            author={i === 0 ? post.data.author : undefined}
            isLead={i === 0}
          />
        ))}
      </ol>
    ) : (
      <p class="text-muted py-8 font-sans">No published essays yet. Check back soon.</p>
    )}
  </section>

  <Sidebar slot="sidebar" />
</BaseLayout>

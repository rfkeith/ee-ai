---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingEntry from '../components/ReadingEntry.astro';
import Sidebar from '../components/Sidebar.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recent = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const totalCount = posts.length;
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for isn't here. Try one of the essays below."
  dekStrong="404 — page not found."
  dek="The page you were looking for isn't here. It may have been moved, renamed, or never existed. Try one of the essays below, or browse by department in the sidebar."
  meta="Error 404"
>
  <section>
    <div class="mb-10">
      <span class="font-mono text-[0.7rem] tracking-[0.14em] uppercase text-accent font-medium">Error 404</span>
      <h1 class="font-sans font-medium text-ink text-[clamp(2rem,3.6vw,3rem)] leading-[1.08] tracking-[-0.024em] m-0 mt-3 mb-4 max-w-[24ch]">
        We couldn't find that page.
      </h1>
      <p class="font-sans text-[1.1rem] leading-snug text-muted m-0 max-w-[56ch]">
        Three options from here: read one of the recent essays below, jump to a department from the sidebar, or head back to the
        <a href="/" class="text-accent underline decoration-rule underline-offset-2 hover:decoration-accent">reading list</a>.
      </p>
    </div>

    <div class="flex justify-between items-baseline mb-5">
      <h2 class="font-sans font-medium text-[0.95rem] tracking-[-0.005em] text-ink m-0">Recent essays</h2>
      <span class="font-mono text-[0.7rem] text-muted-soft">{totalCount} {totalCount === 1 ? 'total' : 'in the archive'}</span>
    </div>

    {recent.length > 0 ? (
      <ol class="list-none m-0 p-0">
        {recent.map((post, i) => (
          <ReadingEntry
            num={totalCount - i}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            url={`/blog/${post.id}/`}
            isLead={i === 0}
          />
        ))}
      </ol>
    ) : (
      <p class="text-muted py-8 font-sans">No published essays yet.</p>
    )}
  </section>

  <Sidebar slot="sidebar" />
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingEntry from '../../../components/ReadingEntry.astro';
import Sidebar from '../../../components/Sidebar.astro';

const categoryMeta: Record<string, { label: string; dekStrong: string; dek: string }> = {
  leadership: {
    label: 'Leadership',
    dekStrong: 'On leading engineers.',
    dek: 'Building teams that grow. Shielding well, exposing wisely, and the practical craft of running an engineering org.',
  },
  'best-practices': {
    label: 'Best Practices',
    dekStrong: 'On the craft of the work.',
    dek: 'Habits, frameworks, and small acts of engineering discipline that compound across a career.',
  },
  career: {
    label: 'Career',
    dekStrong: 'On the jumps that aren’t easy.',
    dek: 'Honest accounts of the senior-to-staff transition, the IC-to-manager pivot, and the moves that make a career.',
  },
  ai: {
    label: 'AI',
    dekStrong: 'On what AI changes, and what it doesn’t.',
    dek: 'Activity-by-activity analysis of where AI replaces engineering work, where it amplifies it, and which skills now matter most.',
  },
};

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];

  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
const meta = categoryMeta[category] ?? { label: category, dekStrong: category, dek: '' };
const totalCount = posts.length;
---

<BaseLayout
  title={meta.label}
  description={`Essays on ${meta.label.toLowerCase()}`}
  dekStrong={meta.dekStrong}
  dek={meta.dek}
>
  <section>
    <div class="flex justify-between items-baseline mb-5">
      <h1 class="font-sans font-medium text-[0.95rem] tracking-[-0.005em] text-ink m-0">
        <span class="text-accent uppercase tracking-[0.14em] text-[0.7rem] mr-2">Department</span>
        {meta.label}
      </h1>
      <span class="font-mono text-[0.7rem] text-muted-soft">
        {totalCount} {totalCount === 1 ? 'essay' : 'essays'}
      </span>
    </div>

    {posts.length > 0 ? (
      <ol class="list-none m-0 p-0">
        {posts.map((post: any, i: number) => (
          <ReadingEntry
            num={totalCount - i}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            url={`/blog/${post.id}/`}
          />
        ))}
      </ol>
    ) : (
      <p class="text-muted py-8 font-sans">No essays in this department yet.</p>
    )}
  </section>

  <Sidebar slot="sidebar" currentCategory={category} />
</BaseLayout>

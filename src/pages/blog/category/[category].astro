---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingEntry from '../../../components/ReadingEntry.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { departments } from '../../../lib/departments';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  // Imports DO reach getStaticPaths even though module-level consts don't,
  // so departments here is the single source of truth.
  return departments.map((dept) => ({
    params: { category: dept.slug },
    props: {
      category: dept.slug,
      posts: posts
        .filter((p) => p.data.category === dept.slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
const meta = departments.find((d) => d.slug === category) ?? { label: category, dekStrong: category, dek: '' };
const totalCount = posts.length;
---

<BaseLayout
  title={meta.label}
  description={`Essays on ${meta.label.toLowerCase()}`}
  dekStrong={meta.dekStrong}
  dek={meta.dek}
>
  <section>
    <div class="flex justify-between items-baseline mb-5">
      <h1 class="font-sans font-medium text-[0.95rem] tracking-[-0.005em] text-ink m-0">
        <span class="text-accent uppercase tracking-[0.14em] text-[0.7rem] mr-2">Department</span>
        {meta.label}
      </h1>
      <span class="font-mono text-[0.7rem] text-muted-soft">
        {totalCount} {totalCount === 1 ? 'essay' : 'essays'}
      </span>
    </div>

    {posts.length > 0 ? (
      <ol class="list-none m-0 p-0">
        {posts.map((post: any, i: number) => (
          <ReadingEntry
            num={totalCount - i}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            url={`/blog/${post.id}/`}
          />
        ))}
      </ol>
    ) : (
      <p class="text-muted py-8 font-sans">No essays in this department yet.</p>
    )}
  </section>

  <Sidebar slot="sidebar" currentCategory={category} />
</BaseLayout>
